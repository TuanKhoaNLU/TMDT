APP_FRONTEND_URL=http://localhost:5173

MYSQL_URL=jdbc:mysql://localhost:3306/e_commerce?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Ho_Chi_Minh&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USER=root
MYSQL_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379

DEFAULT_BUYER_ID=1
DEFAULT_SHOP_ID=1
CART_TTL_DAYS=7
COMMISSION_RATE=0.10

# GHN is used for province/district/ward data and shipping fee.
# Checkout shipping address and fee will fail with 503 if these are missing.
GHN_TOKEN=replace_with_ghn_token
GHN_SHOP_ID=replace_with_ghn_shop_id
GHN_BASE_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_FROM_DISTRICT_ID=1442
GHN_FROM_WARD_CODE=20101
GHN_SERVICE_TYPE_ID=2
GHN_PAYMENT_TYPE_ID=2
GHN_REQUIRED_NOTE=CHOXEMHANGKHONGTHU
GHN_PACKAGE_LENGTH=20
GHN_PACKAGE_WIDTH=15
GHN_PACKAGE_HEIGHT=10
GHN_FROM_NAME=
GHN_FROM_PHONE=
GHN_FROM_ADDRESS=
GHN_FROM_WARD_NAME=
GHN_FROM_DISTRICT_NAME=
GHN_FROM_PROVINCE_NAME=
GHN_RETURN_PHONE=
GHN_RETURN_ADDRESS=
GHN_RETURN_DISTRICT_ID=
GHN_RETURN_WARD_CODE=

# Set false for real VNPay sandbox redirect.
# If false, VNPAY_HASH_SECRET must be the sandbox secret from VNPay.
VNPAY_MOCK_ENABLED=false
VNPAY_TMN_CODE=replace_with_vnpay_tmn_code
VNPAY_HASH_SECRET=replace_with_vnpay_hash_secret
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment-result
